ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false

POSTGRES_DB=nldb
POSTGRES_USER=nldb_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

DATABASE_URL=postgresql+asyncpg://nldb_user:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@postgres:5432/nldb
REDIS_URL=redis://redis:6379/0

OPENROUTER_API_KEY=REPLACE_WITH_REAL_KEY
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60

MAX_RESULT_ROWS=500
QUERY_TIMEOUT_SECONDS=15
SENSITIVE_COLUMNS=["password","phone","national_id","credit_card","email"]
BLACKLISTED_TABLES=["users_auth","audit_logs","alembic_version"]
CORS_ORIGINS=["http://localhost:8080"]
REQUEST_SLOW_THRESHOLD_SECONDS=1.0
BACKEND_URL=http://backend:8000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
